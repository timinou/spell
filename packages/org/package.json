{
	"type": "module",
	"name": "@oh-my-pi/pi-org",
	"version": "13.10.1",
	"description": "Org-mode project management system for Pi",
	"homepage": "https://github.com/can1357/oh-my-pi",
	"author": "Can Boluk",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/org"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "tsgo -p tsconfig.json",
		"test": "bun test"
	},
	"dependencies": {
		"@oh-my-pi/pi-utils": "workspace:*",
		"@sinclair/typebox": "^0.34",
		"hast-util-to-mdast": "10.1.2",
		"mdast-util-to-markdown": "2.1.2",
		"orgast-util-to-string": "1.1.0",
		"uniorg": "1.3.0",
		"uniorg-parse": "3.2.0",
		"uniorg-rehype": "2.2.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src",
		"elisp"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
