{
	"type": "module",
	"name": "@oh-my-pi/pi-niri",
	"version": "0.1.0",
	"description": "Niri compositor IPC client and overview overlay for pi",
	"homepage": "https://github.com/can1357/oh-my-pi",
	"author": "Can Boluk",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/niri"
	},
	"bugs": {
		"url": "https://github.com/can1357/oh-my-pi/issues"
	},
	"keywords": [
		"niri",
		"wayland",
		"ipc",
		"tui"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "tsgo -p tsconfig.json"
	},
	"dependencies": {
		"@oh-my-pi/pi-tui": "workspace:*",
		"@oh-my-pi/pi-utils": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3"
	},
	"engines": {
		"bun": ">=1.3.7"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
